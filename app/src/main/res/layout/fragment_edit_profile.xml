<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F2"
    tools:context=".fragments.EditProfileFragment">

  <androidx.core.widget.NestedScrollView
      android:id="@+id/nestedScrollView"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#F2F6F2"
      android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

      <!-- ===== HEADER ===== -->
      <androidx.constraintlayout.widget.ConstraintLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/bg_header_deep"
          android:paddingBottom="56dp">

        <!-- Decorative top-right circle -->
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="-40dp"
            android:layout_marginEnd="-40dp"
            android:alpha="0.05"
            android:background="@drawable/bg_circle_plain"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Decorative bottom-left circle -->
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginStart="-20dp"
            android:layout_marginTop="80dp"
            android:alpha="0.04"
            android:background="@drawable/bg_circle_plain"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

          <ImageView
              android:layout_width="20dp"
              android:layout_height="20dp"
              android:layout_gravity="center"
              android:src="@drawable/ic_arrow_back"
              app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <!-- Title + subtitle beside back button -->
        <LinearLayout
            android:id="@+id/titleBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack">

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Edit Profile"
              android:textColor="#FFFFFF"
              android:textSize="18sp"
              android:textStyle="bold" />

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="UPDATE YOUR INFORMATION"
              android:textColor="#A8D5AA"
              android:textSize="9sp"
              android:letterSpacing="0.1"
              android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Gold ring -->
        <View
            android:id="@+id/profileRing"
            android:layout_width="98dp"
            android:layout_height="98dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ring_gold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <!-- Profile image -->
        <androidx.cardview.widget.CardView
            android:id="@+id/profileImageCard"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

          <com.google.android.material.imageview.ShapeableImageView
              android:id="@+id/editProfileImage"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:scaleType="centerCrop"
              android:src="@drawable/ic_profile_placeholder"
              app:shapeAppearanceOverlay="@style/CircleImage" />
        </androidx.cardview.widget.CardView>

        <!-- Camera badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnChangePhoto"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="76dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#C9A84C"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            app:layout_constraintStart_toEndOf="@id/profileImageCard"
            app:layout_constraintEnd_toEndOf="@id/profileImageCard"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

          <ImageView
              android:layout_width="14dp"
              android:layout_height="14dp"
              android:layout_gravity="center"
              android:src="@drawable/ic_camera"
              app:tint="#FFFFFF" />
        </com.google.android.material.card.MaterialCardView>

        <!-- "Tap to change photo" label -->
        <TextView
            android:id="@+id/tapToChangeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="TAP CAMERA TO CHANGE PHOTO"
            android:textColor="#80FFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.08"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileImageCard" />

      </androidx.constraintlayout.widget.ConstraintLayout>

      <!-- ===== FORM CARD (overlaps header using negative margin) ===== -->
      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="18dp"
          android:layout_marginEnd="18dp"
          android:layout_marginTop="-32dp"
          android:layout_marginBottom="24dp"
          app:cardCornerRadius="28dp"
          app:cardElevation="16dp"
          app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="26dp"
            android:paddingBottom="26dp">

          <!-- Section header with green bar -->
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:layout_marginBottom="22dp">

            <View
                android:layout_width="4dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_green_bar"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="Personal Details"
                  android:textColor="#1A3E1A"
                  android:textSize="17sp"
                  android:textStyle="bold" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="Update your account details"
                  android:textColor="#90A4AE"
                  android:textSize="11sp"
                  android:layout_marginTop="2dp" />
            </LinearLayout>
          </LinearLayout>

          <!-- Full Name -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Full Name"
              android:textColor="#37474F"
              android:textSize="11sp"
              android:textStyle="bold"
              android:letterSpacing="0.06"
              android:textAllCaps="true"
              android:layout_marginBottom="7dp" />

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:layout_marginBottom="16dp"
              android:background="@drawable/bg_input_refined"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingStart="14dp"
              android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person_outline"
                app:tint="#2E7D32" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Enter your name"
                android:inputType="textPersonName"
                android:textColor="#1A2E1A"
                android:textColorHint="#C0C8C0"
                android:textSize="14sp" />
          </LinearLayout>

          <!-- Email -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Email Address"
              android:textColor="#37474F"
              android:textSize="11sp"
              android:textStyle="bold"
              android:letterSpacing="0.06"
              android:textAllCaps="true"
              android:layout_marginBottom="7dp" />

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:layout_marginBottom="16dp"
              android:background="@drawable/bg_input_refined"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingStart="14dp"
              android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_email_outline"
                app:tint="#2E7D32" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Enter your email"
                android:inputType="textEmailAddress"
                android:textColor="#1A2E1A"
                android:textColorHint="#C0C8C0"
                android:textSize="14sp" />
          </LinearLayout>

          <!-- Department -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Department"
              android:textColor="#37474F"
              android:textSize="11sp"
              android:textStyle="bold"
              android:letterSpacing="0.06"
              android:textAllCaps="true"
              android:layout_marginBottom="7dp" />

          <RelativeLayout
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:layout_marginBottom="16dp"
              android:background="@drawable/bg_input_refined">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp"
                android:src="@drawable/ic_building_outline"
                app:tint="#2E7D32" />

            <Spinner
                android:id="@+id/spinnerDepartment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="42dp"
                android:layout_marginEnd="36dp"
                android:background="@android:color/transparent"
                android:spinnerMode="dropdown" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="#90A4AE" />
          </RelativeLayout>

          <!-- New Password -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="New Password"
              android:textColor="#37474F"
              android:textSize="11sp"
              android:textStyle="bold"
              android:letterSpacing="0.06"
              android:textAllCaps="true"
              android:layout_marginBottom="7dp" />

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:background="@drawable/bg_input_refined"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingStart="14dp"
              android:paddingEnd="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock_outline"
                app:tint="#2E7D32" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Enter new password"
                android:inputType="textPassword"
                android:textColor="#1A2E1A"
                android:textColorHint="#C0C8C0"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/togglePassword"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_eye_off"
                app:tint="#B0BEC5" />
          </LinearLayout>

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Leave blank to keep your current password"
              android:textColor="#90A4AE"
              android:textSize="11sp"
              android:layout_marginTop="6dp"
              android:layout_marginBottom="24dp" />

          <!-- Save Button -->
          <com.google.android.material.button.MaterialButton
              android:id="@+id/btnSaveProfile"
              android:layout_width="match_parent"
              android:layout_height="54dp"
              app:backgroundTint="#1B5E20"
              android:text="Save Changes"
              android:textAllCaps="false"
              android:textColor="#FFFFFF"
              android:textSize="15sp"
              android:textStyle="bold"
              android:letterSpacing="0.04"
              app:cornerRadius="14dp"
              app:icon="@drawable/ic_save"
              app:iconGravity="textStart"
              app:iconTint="#81C784" />

        </LinearLayout>
      </androidx.cardview.widget.CardView>

      <!-- Footer -->
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:layout_marginBottom="24dp"
          android:text="© 2026 UPSmart Canteen · UPang"
          android:textColor="#B0BEC5"
          android:textSize="10sp" />

    </LinearLayout>
  </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>