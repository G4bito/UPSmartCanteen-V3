<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== IMAGE SECTION ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- Food image -->
            <ImageView
                android:id="@+id/dialogFoodImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/food_image" />

            <!-- Bottom gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_image_gradient_overlay" />

            <!-- Close button (top left) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnCloseDialog"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_margin="12dp"
                app:cardCornerRadius="17dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#EDFFFFFF">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_close"
                    app:tint="#1B5E20" />
            </androidx.cardview.widget.CardView>

            <!-- Category badge (top right) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/categoryBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#EDFFFFFF">

                <TextView
                    android:id="@+id/dialogFoodCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="SNACKS"
                    android:textColor="#2E7D32"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </androidx.cardview.widget.CardView>

            <!-- Status badge (below category) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="44dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#D91B5E20">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_status_dot_open" />

                    <TextView
                        android:id="@+id/dialogFoodStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Price (bottom left over image) -->
            <TextView
                android:id="@+id/dialogFoodPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="12dp"
                android:text="₱0.00"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:shadowColor="#60000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6" />

            <!-- Stock (bottom right over image) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/stockBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#66000000">

                <TextView
                    android:id="@+id/dialogFoodStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Stocks: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </FrameLayout>

        <!-- ===== CONTENT SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Food name + stall -->
            <TextView
                android:id="@+id/dialogFoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food Name"
                android:textColor="#1A3E1A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_stalls"
                    app:tint="#90A4AE" />

                <TextView
                    android:id="@+id/dialogFoodStall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By Stall Name"
                    android:textColor="#90A4AE"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F0"
                android:layout_marginBottom="12dp" />

            <!-- Description -->
            <TextView
                android:id="@+id/dialogFoodDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delicious food description goes here."
                android:textColor="#78909C"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F0"
                android:layout_marginBottom="14dp" />

            <!-- Quantity + subtotal row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Quantity control -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUANTITY"
                        android:textColor="#90A4AE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_quantity_control"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/btnMinus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:padding="10dp"
                            android:src="@drawable/ic_minus"
                            app:tint="#2E7D32" />

                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#1A3E1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnPlus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#1B5E20">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_add"
                                app:tint="#FFFFFF" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Subtotal -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUBTOTAL"
                        android:textColor="#90A4AE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱0.00"
                        android:textColor="#1B5E20"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Add to Cart button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:backgroundTint="#1B5E20"
                android:text="Add to Cart"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_cart"
                app:iconGravity="textStart"
                app:iconTint="#81C784" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>