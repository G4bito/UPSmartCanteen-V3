<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F2"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="650dp">

        <!-- Header background -->
        <View
            android:id="@+id/headerBg"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_header_deep"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Decorative top-right circle -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-50dp"
            android:alpha="0.06"
            android:background="@drawable/bg_circle_plain"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Decorative bottom-left circle -->
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="-30dp"
            android:layout_marginTop="130dp"
            android:alpha="0.05"
            android:background="@drawable/bg_circle_plain"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back button (top-left) -->

        <!-- Lock icon box -->

        <!-- Title -->

        <!-- Gold underline -->

        <androidx.cardview.widget.CardView
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="22dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#22FFFFFF"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/lockIconBox"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#1EFFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock_outline"
                app:tint="#C9A84C" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:lineSpacingMultiplier="1.1"
            android:text="Forgot\nPassword?"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lockIconBox" />

        <!-- Subtitle -->

        <!-- Form Card -->

        <View
            android:id="@+id/titleUnderline"
            android:layout_width="36dp"
            android:layout_height="2dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:background="#C9A84C"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="2dp"
            android:letterSpacing="0.1"
            android:text="ACCOUNT RECOVERY"
            android:textColor="#A8D5AA"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleUnderline" />

        <androidx.cardview.widget.CardView
            android:id="@+id/formCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="229dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <!-- Section header with green bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_green_bar" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reset your password"
                            android:textColor="#1A3E1A"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Enter your email to receive a reset code"
                            android:textColor="#90A4AE"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Info chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="22dp"
                    android:background="@drawable/bg_terms_chip"
                    android:gravity="top"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginTop="1dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_info"
                        app:tint="#2E7D32" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:lineSpacingMultiplier="1.4"
                        android:text="We'll send a password reset code to your registered email address."
                        android:textColor="#546E7A"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="7dp"
                    android:letterSpacing="0.06"
                    android:text="Email Address"
                    android:textAllCaps="true"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Email Input -->
                <LinearLayout
                    android:id="@+id/emailContainer"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="26dp"
                    android:background="@drawable/bg_input_refined"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_email_outline"
                        app:tint="#2E7D32" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="you@gmail.com"
                        android:inputType="textEmailAddress"
                        android:textColor="#1A2E1A"
                        android:textColorHint="#C0C8C0"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:indeterminateTint="#2E7D32"
                    android:visibility="gone" />

                <!-- Send Reset Link Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendReset"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:letterSpacing="0.04"
                    android:text="Send Reset Code"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#1B5E20"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_login"
                    app:iconGravity="textEnd"
                    app:iconTint="#81C784" />

                <!-- OR Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0EDE0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="14dp"
                        android:letterSpacing="0.1"
                        android:text="OR"
                        android:textColor="#B0BEC5"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0EDE0" />
                </LinearLayout>

                <!-- Back to Sign In Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToLogin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Back to Sign In"
                    android:textAllCaps="false"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_back"
                    app:iconGravity="textStart"
                    app:iconTint="#2E7D32"
                    app:strokeColor="#A5D6A7"
                    app:strokeWidth="1.5dp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="28dp"
            android:text="© 2026 UPSmart Canteen · UPang"
            android:textColor="#B0BEC5"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/formCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>