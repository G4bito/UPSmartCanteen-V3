<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F2"
    android:fillViewport="true">

  <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:minHeight="800dp">

    <!-- Header background -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_header_deep"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Decorative top-right circle -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp"
        android:alpha="0.06"
        android:background="@drawable/bg_circle_plain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Decorative bottom-left circle -->
    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="120dp"
        android:alpha="0.05"
        android:background="@drawable/bg_circle_plain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Gold pill at top -->
    <View
        android:id="@+id/goldPill"
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/bg_gold_pill"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title: Create Account -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:text="Create\nAccount"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Gold underline -->
    <View
        android:id="@+id/titleUnderline"
        android:layout_width="36dp"
        android:layout_height="2dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:background="#C9A84C"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:text="JOIN UPSMART CANTEEN"
        android:textColor="#A8D5AA"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleUnderline" />

    <!-- Form Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/formCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="168dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingStart="24dp"
          android:paddingEnd="24dp"
          android:paddingTop="26dp"
          android:paddingBottom="24dp">

        <!-- Section header with green bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="22dp">

          <View
              android:layout_width="4dp"
              android:layout_height="32dp"
              android:background="@drawable/bg_green_bar"
              android:layout_marginEnd="10dp" />

          <LinearLayout
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Details"
                android:textColor="#1A3E1A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your information below"
                android:textColor="#90A4AE"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
          </LinearLayout>
        </LinearLayout>

        <!-- Employee ID Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Employee ID"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Employee ID Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_refined"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

          <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:src="@drawable/ic_id_card"
              app:tint="#2E7D32" />

          <EditText
              android:id="@+id/etEmployeeId"
              android:layout_width="0dp"
              android:layout_height="match_parent"
              android:layout_marginStart="10dp"
              android:layout_weight="1"
              android:background="@android:color/transparent"
              android:hint="EMP-###"
              android:inputType="text"
              android:textColor="#1A2E1A"
              android:textColorHint="#C0C8C0"
              android:textSize="14sp" />
        </LinearLayout>

        <!-- Full Name Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Full Name Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_refined"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

          <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:src="@drawable/ic_person_outline"
              app:tint="#2E7D32" />

          <EditText
              android:id="@+id/etFullName"
              android:layout_width="0dp"
              android:layout_height="match_parent"
              android:layout_marginStart="10dp"
              android:layout_weight="1"
              android:background="@android:color/transparent"
              android:hint="Full Name"
              android:inputType="textPersonName"
              android:textColor="#1A2E1A"
              android:textColorHint="#C0C8C0"
              android:textSize="14sp" />
        </LinearLayout>

        <!-- Email Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Email Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_refined"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

          <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:src="@drawable/ic_email_outline"
              app:tint="#2E7D32" />

          <EditText
              android:id="@+id/etEmail"
              android:layout_width="0dp"
              android:layout_height="match_parent"
              android:layout_marginStart="10dp"
              android:layout_weight="1"
              android:background="@android:color/transparent"
              android:hint="Phinmaed or Gmail"
              android:inputType="textEmailAddress"
              android:textColor="#1A2E1A"
              android:textColorHint="#C0C8C0"
              android:textSize="14sp" />
        </LinearLayout>

        <!-- Department Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Department"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Department Spinner -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_refined">

          <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:layout_centerVertical="true"
              android:layout_marginStart="14dp"
              android:src="@drawable/ic_building_outline"
              app:tint="#2E7D32" />

          <Spinner
              android:id="@+id/spinnerDepartment"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:layout_marginStart="42dp"
              android:layout_marginEnd="36dp"
              android:background="@android:color/transparent"
              android:spinnerMode="dropdown" />

          <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:layout_alignParentEnd="true"
              android:layout_centerVertical="true"
              android:layout_marginEnd="14dp"
              android:src="@drawable/ic_chevron_down"
              app:tint="#90A4AE" />
        </RelativeLayout>

        <!-- Password Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_input_refined"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#90A4AE"
            app:boxBackgroundMode="none">

          <com.google.android.material.textfield.TextInputEditText
              android:id="@+id/etPassword"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@android:color/transparent"
              android:hint="Password"
              android:inputType="textPassword"
              android:paddingStart="14dp"
              android:paddingEnd="48dp"
              android:textColor="#1A2E1A"
              android:textColorHint="#C0C8C0"
              android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Min 8 chars, uppercase, number &amp; symbol"
            android:textColor="#90A4AE"
            android:textSize="11sp"
            android:layout_marginBottom="14dp"
            android:layout_marginStart="4dp" />

        <!-- Confirm Password Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="#37474F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <!-- Confirm Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_input_refined"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#90A4AE"
            app:boxBackgroundMode="none">

          <com.google.android.material.textfield.TextInputEditText
              android:id="@+id/etConfirmPassword"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@android:color/transparent"
              android:hint="Confirm Password"
              android:inputType="textPassword"
              android:paddingStart="14dp"
              android:paddingEnd="48dp"
              android:textColor="#1A2E1A"
              android:textColorHint="#C0C8C0"
              android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Terms checkbox row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_terms_chip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

          <CheckBox
              android:id="@+id/cbTerms"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginEnd="8dp"
              app:buttonTint="#2E7D32" />

          <TextView
              android:id="@+id/tvTermsAndPrivacy"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="I agree to the Terms &amp; Conditions"
              android:textColor="#546E7A"
              android:textSize="12sp" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:indeterminateTint="#2E7D32" />

        <!-- Sign Up Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            app:backgroundTint="#1B5E20"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_login"
            app:iconGravity="textEnd"
            app:iconTint="#81C784" />

        <!-- Already have account -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Already have an account? "
              android:textColor="#90A4AE"
              android:textSize="13sp" />

          <TextView
              android:id="@+id/tvLogin"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Sign In"
              android:textColor="#2E7D32"
              android:textSize="13sp"
              android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="4dp" />

      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="28dp"
        android:text="© 2026 UPSmart Canteen · UPang"
        android:textColor="#B0BEC5"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/formCard" />

  </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>