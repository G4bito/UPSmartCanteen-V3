<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".fragments.PrivacyFragment">

  <com.google.android.material.appbar.AppBarLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="#F8F9FA"
      app:elevation="0dp"
      app:liftOnScroll="false">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F8F9FA"
        app:navigationIcon="@drawable/ic_back">

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:text="Privacy Policy"
          android:textColor="#333333"
          android:textSize="18sp"
          android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>
  </com.google.android.material.appbar.AppBarLayout>

  <androidx.core.widget.NestedScrollView
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#F8F9FA"
      app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Privacy Policy"
          android:textColor="#333333"
          android:textSize="22sp"
          android:textStyle="bold" />

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="8dp"
          android:text="Last updated: February 10, 2024"
          android:textColor="#999999"
          android:textSize="13sp" />

      <com.google.android.material.card.MaterialCardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="24dp"
          app:cardBackgroundColor="#FFFFFF"
          app:cardCornerRadius="16dp"
          app:cardElevation="0dp"
          app:strokeColor="#F0F0F0"
          app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Data Collection"
              android:textColor="#333333"
              android:textSize="15sp"
              android:textStyle="bold" />

          <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="12dp"
              android:lineSpacingExtra="4dp"
              android:text="We collect minimal personal information such as your name, email, and department to provide you with a personalized canteen experience."
              android:textColor="#666666"
              android:textSize="14sp" />

          <View
              android:layout_width="match_parent"
              android:layout_height="1dp"
              android:layout_marginVertical="20dp"
              android:background="#F0F0F0" />

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Usage of Data"
              android:textColor="#333333"
              android:textSize="15sp"
              android:textStyle="bold" />

          <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="12dp"
              android:lineSpacingExtra="4dp"
              android:text="Your data is primarily used to process orders and identify users within the campus canteen system. We do not sell your personal data to third parties."
              android:textColor="#666666"
              android:textSize="14sp" />

          <View
              android:layout_width="match_parent"
              android:layout_height="1dp"
              android:layout_marginVertical="20dp"
              android:background="#F0F0F0" />

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Security"
              android:textColor="#333333"
              android:textSize="15sp"
              android:textStyle="bold" />

          <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="12dp"
              android:lineSpacingExtra="4dp"
              android:text="We implement standard security measures to protect your account information. However, no digital storage is 100% secure."
              android:textColor="#666666"
              android:textSize="14sp" />

        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
  </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>