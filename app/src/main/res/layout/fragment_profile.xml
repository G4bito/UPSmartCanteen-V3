<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F2"
    android:fillViewport="true"
    tools:context=".fragments.ProfileFragment">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

    <!-- Marquee top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D3311"
        android:gravity="center"
        android:paddingVertical="7dp">

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:letterSpacing="0.12"
          android:text="PHINMA EDUCATION  •  PARTIA VIRTUS SCIENTIA"
          android:textColor="#C9A84C"
          android:textSize="9sp"
          android:textStyle="bold" />
    </LinearLayout>

    <!-- Header section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_deep"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="56dp">

      <!-- Decorative circles -->
      <View
          android:layout_width="160dp"
          android:layout_height="160dp"
          android:layout_marginTop="-40dp"
          android:layout_marginEnd="-40dp"
          android:alpha="0.05"
          android:background="@drawable/bg_circle_plain"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toTopOf="parent" />

      <View
          android:layout_width="100dp"
          android:layout_height="100dp"
          android:layout_marginStart="-20dp"
          android:layout_marginTop="80dp"
          android:alpha="0.04"
          android:background="@drawable/bg_circle_plain"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent" />

      <!-- Help icon -->
      <androidx.cardview.widget.CardView
          android:id="@+id/onboardingInfoIcon"
          android:layout_width="38dp"
          android:layout_height="38dp"
          android:layout_marginTop="16dp"
          android:layout_marginEnd="16dp"
          app:cardCornerRadius="10dp"
          app:cardElevation="0dp"
          app:cardBackgroundColor="#22FFFFFF"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_help"
            app:tint="#FFFFFF" />
      </androidx.cardview.widget.CardView>

      <!-- Profile image with gold ring -->
      <View
          android:id="@+id/profileRing"
          android:layout_width="104dp"
          android:layout_height="104dp"
          android:layout_marginTop="28dp"
          android:background="@drawable/bg_ring_gold"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent" />

      <androidx.cardview.widget.CardView
          android:id="@+id/profileCard"
          android:layout_width="96dp"
          android:layout_height="96dp"
          android:layout_marginTop="32dp"
          app:cardBackgroundColor="#FFFFFF"
          app:cardCornerRadius="48dp"
          app:cardElevation="12dp"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Profile Picture"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_placeholder" />
      </androidx.cardview.widget.CardView>

      <!-- Name -->
      <TextView
          android:id="@+id/userName"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="14dp"
          android:shadowColor="#40000000"
          android:shadowDx="0"
          android:shadowDy="2"
          android:shadowRadius="4"
          android:text="Zyrel Gabriel Maningding"
          android:textColor="#FFFFFF"
          android:textSize="22sp"
          android:textStyle="bold"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@id/profileCard" />

      <!-- Gold separator -->
      <View
          android:id="@+id/nameSeparator"
          android:layout_width="36dp"
          android:layout_height="2dp"
          android:layout_marginTop="8dp"
          android:background="#C9A84C"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@id/userName" />

      <!-- Email -->
      <TextView
          android:id="@+id/userEmail"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="8dp"
          android:text="zyre.maningding.up@phinmaed.com"
          android:textColor="#A8D5AA"
          android:textSize="11sp"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@id/nameSeparator" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-36dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

      <!-- Quick stats card -->
      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          app:cardCornerRadius="20dp"
          app:cardElevation="8dp"
          app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="18dp"
            android:paddingHorizontal="8dp">

          <!-- Total Orders -->
          <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:orientation="vertical">

            <TextView
                android:id="@+id/statOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="#1B5E20"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL ORDERS"
                android:textColor="#90A4AE"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="2dp" />
          </LinearLayout>

          <View
              android:layout_width="1dp"
              android:layout_height="36dp"
              android:layout_gravity="center_vertical"
              android:background="#E0EDE0" />

          <!-- Total Spent -->
          <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:orientation="vertical">

            <TextView
                android:id="@+id/statSpent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱480"
                android:textColor="#1B5E20"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL SPENT"
                android:textColor="#90A4AE"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="2dp" />
          </LinearLayout>

        </LinearLayout>
      </androidx.cardview.widget.CardView>

      <!-- Row 1: Edit Profile + History -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/editProfileCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_edit"
                  app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Edit Profile"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update info"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/orderHistoryCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_history"
                  app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="History"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Past orders"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
      </LinearLayout>

      <!-- Row 2: Payment + Notifications -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/paymentCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF8E1">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_payment"
                  app:tint="#C9A84C" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Payment"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage cards"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/notificationsCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_notifications"
                  app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Notifications"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts &amp; updates"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
      </LinearLayout>

      <!-- Row 3: Support + About -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="20dp"
          android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/helpCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_help"
                  app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Support"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get help"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/aboutCard"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:gravity="start"
              android:orientation="vertical"
              android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">

              <ImageView
                  android:layout_width="20dp"
                  android:layout_height="20dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_info"
                  app:tint="#2E7D32" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="About"
                android:textColor="#1A3E1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App info"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
      </LinearLayout>

      <!-- Logout button -->
      <com.google.android.material.button.MaterialButton
          android:id="@+id/logoutButton"
          android:layout_width="match_parent"
          android:layout_height="54dp"
          android:layout_marginBottom="12dp"
          android:text="Log Out"
          android:textAllCaps="false"
          android:textColor="#FFFFFF"
          android:textSize="15sp"
          android:textStyle="bold"
          android:letterSpacing="0.04"
          app:backgroundTint="#1B5E20"
          app:cornerRadius="16dp"
          app:elevation="4dp"
          app:icon="@drawable/ic_logout"
          app:iconGravity="textStart"
          app:iconTint="#81C784" />

      <!-- Footer -->
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:layout_marginTop="4dp"
          android:text="© 2026 UPSmart Canteen · UPang"
          android:textColor="#B0BEC5"
          android:textSize="10sp" />

    </LinearLayout>
  </LinearLayout>
</androidx.core.widget.NestedScrollView>