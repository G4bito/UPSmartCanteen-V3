<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Use android:width instead of percentage for older systems,
         or just a simplified shape for now to fix build.
         Percentage is not supported in the 'right' attribute. -->
    <item android:gravity="left">
        <shape android:shape="rectangle">
            <solid android:color="#1B5E20" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>